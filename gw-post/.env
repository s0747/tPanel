
GW_BIND_ADDR=0.0.0.0:4000
GW_MQTT_BROKER_URL=mqtt://localhost:1883
GW_MQTT_TOPIC_PREFIX=sensors
GW_DEFAULT_SENSOR_ID=default

TEMP_MIN=15.0
TEMP_MAX=35.0
HUMIDITY_MIN=20.0
HUMIDITY_MAX=90.0

# ─── Auto-blacklista ──────────────────────────────────────────────────────────

# Liczba błędów auth przed zablokowaniem IP
GW_BLACKLIST_THRESHOLD=5

# Okno czasowe zliczania błędów (sekundy)
GW_BLACKLIST_WINDOW=60

# Czas blokady IP (sekundy)
GW_BLACKLIST_BAN_DURATION=300

RUST_LOG=info

