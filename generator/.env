# ─── generator · plik konfiguracyjny ─────────────────────────────────────────

# Interwał między próbkami w sekundach (obsługuje ułamki: 0.5, 1, 2, 60)
GENERATOR_INTERVAL=2

# Zakresy wartości — odczyty obcinane do tych granic
TEMP_MIN=15.0
TEMP_MAX=35.0
HUMIDITY_MIN=20.0
HUMIDITY_MAX=90.0

# Maksymalny krok random walk per próbka
TEMP_STEP=0.5
HUMIDITY_STEP=1.0
