# ─── core · plik konfiguracyjny ──────────────────────────────────────────

# Adres HTTP API
CORE_BIND_ADDR=0.0.0.0:4001

# URL brokera MQTT
CORE_MQTT_BROKER_URL=mqtt://localhost:1883

# Client ID (musi być unikalny)
CORE_MQTT_CLIENT_ID=archiver-01

# Topic subskrypcji (wildcard)
CORE_MQTT_TOPIC=sensors/#

# Ścieżka do pliku SQLite
CORE_DB_PATH=./data/readings.db

# Maksymalna liczba połączeń w puli
CORE_DB_MAX_CONN=5

# Maksymalna liczba punktów zwracanych przez /api/range
CORE_API_MAX_POINTS=86400

# Poziom logowania
RUST_LOG=info
