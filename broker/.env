# ─── mqtt-broker · plik konfiguracyjny ───────────────────────────────────────

# ─── Broker — TCP ─────────────────────────────────────────────────────────────
MQTT_TCP_ADDR=0.0.0.0:1883

# ─── Broker — TLS (opcjonalny, pusty = wyłączony) ─────────────────────────────
MQTT_TLS_ADDR=
MQTT_TLS_CERT=certs/server.crt
MQTT_TLS_KEY=certs/server.key

# ─── Broker — QUIC (opcjonalny, pusty = wyłączony) ────────────────────────────
# Wymaga tych samych certyfikatów co TLS
MQTT_QUIC_ADDR=

# ─── Bridge ───────────────────────────────────────────────────────────────────

# Topic MQTT na który subskrybuje bridge (wildcard MQTT)
# sensors/#        → wszystkie wiadomości pod sensors/
# sensors/+/data   → tylko sensors/{id}/data
BRIDGE_TOPIC=sensors/#

# URL endpointu POST weather-dashboard
BRIDGE_TARGET_URL=http://localhost:3000/twój-uuid/

# true  → sensor_id wyciągany z nazwy topicu: sensors/{sensor_id}/data
# false → sensor_id z pola JSON payloadu
BRIDGE_SENSOR_ID_FROM_TOPIC=true

# Domyślny sensor_id gdy nie można wyciągnąć z topicu ani payloadu
BRIDGE_DEFAULT_SENSOR_ID=mqtt-sensor

# Client ID bridge'a w brokerze (musi być unikalny)
BRIDGE_CLIENT_ID=mqtt-bridge-01

# ─── Logowanie ────────────────────────────────────────────────────────────────
# Poziomy: error, warn, info, debug, trace
RUST_LOG=info
